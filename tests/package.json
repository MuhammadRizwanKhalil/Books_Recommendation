{
  "name": "thebooktimes-tests",
  "version": "1.0.0",
  "description": "Playwright E2E + API tests for TheBookTimes",
  "scripts": {
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:ui": "playwright test --config=playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config=playwright.config.ts --headed",
    "test:api": "vitest run --config=vitest.config.ts",
    "test:api:watch": "vitest --config=vitest.config.ts",
    "test:all": "npm run test:api && npm run test:e2e",
    "install:browsers": "playwright install"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "node-fetch": "^3.3.2"
  }
}
