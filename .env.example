# ══════════════════════════════════════════════════════════════════════════════
# The Book Times — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Security (REQUIRED in production) ────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
ADMIN_EMAIL=admin@thebooktimes.com
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ── URLs ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed frontend origins for CORS
FRONTEND_URL=https://thebooktimes.com,https://www.thebooktimes.com
# For production with Docker, the API is proxied through nginx at /api
VITE_API_URL=/api
# Port to expose the app on the host (8080 for host Nginx proxy, or 80 for direct)
APP_PORT=8080

# ── Database (MySQL) ─────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=thebooktimes
MYSQL_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
MYSQL_DATABASE=thebooktimes
MYSQL_POOL_SIZE=10

# ── Google Books Import ──────────────────────────────────────────────────────
GOOGLE_BOOKS_API_KEY=
IMPORT_JOB_ENABLED=true
IMPORT_CRON_SCHEDULE=0 3 * * *
IMPORT_RUN_ON_STARTUP=false

# ── Google Analytics (optional) ──────────────────────────────────────────────
GA_MEASUREMENT_ID=G-TDW096P47M
# Numeric GA4 property ID (example: 123456789)
GA_PROPERTY_ID=
# Option A: mounted service account credentials file path
GOOGLE_APPLICATION_CREDENTIALS=./ga-credentials.json
# Option B: raw service account JSON (single-line JSON string)
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# Option C (recommended for CI/CD secrets): base64-encoded service account JSON
# The backend auto-detects base64 values in GOOGLE_APPLICATION_CREDENTIALS_JSON.
# Example (PowerShell):
# [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes((Get-Content .\\server\\ga-credentials.json -Raw)))
# Frontend build-time GA values
VITE_GOOGLE_CLIENT_ID=
# Backend Google ID token verification audience(s):
# Use same value as VITE_GOOGLE_CLIENT_ID, or a comma-separated list if needed.
GOOGLE_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_IDS=
VITE_GA_MEASUREMENT_ID=G-TDW096P47M
VITE_ANALYTICS_ALLOWED_HOSTS=thebooktimes.com,www.thebooktimes.com
VITE_ENABLE_ANALYTICS=false

# ── Email / SMTP (optional) ─────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@thebooktimes.com

# ── OpenAI (for AI blog generation) ─────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── AI Auto Blog Posting ────────────────────────────────────────────────────
AI_BLOG_ENABLED=false
AI_BLOG_CRON_SCHEDULE=0 9 * * 1
AI_BLOG_POSTS_PER_RUN=1
OPENAI_MAX_DAILY_TOKENS=100000

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Data Retention (days) ────────────────────────────────────────────────────
RETENTION_ANALYTICS_DAYS=90
RETENTION_PAGEVIEWS_DAYS=90
RETENTION_WEBVITALS_DAYS=30
RETENTION_AI_LOG_DAYS=180

# ── Backups ──────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=
