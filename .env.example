# ══════════════════════════════════════════════════════════════════════════════
# The Book Times — Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Security (REQUIRED in production) ────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
ADMIN_EMAIL=admin@thebooktimes.com
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost
# For production with Docker, the API is proxied through nginx at /api
VITE_API_URL=/api
# Port to expose the app on the host (8080 for host Nginx proxy, or 80 for direct)
APP_PORT=8080

# ── Database (MySQL) ─────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=thebooktimes
MYSQL_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
MYSQL_DATABASE=thebooktimes
MYSQL_POOL_SIZE=10

# ── Google Books Import ──────────────────────────────────────────────────────
GOOGLE_BOOKS_API_KEY=
IMPORT_JOB_ENABLED=true
IMPORT_CRON_SCHEDULE=0 3 * * *
IMPORT_RUN_ON_STARTUP=false

# ── Google Analytics (optional) ──────────────────────────────────────────────
GA_MEASUREMENT_ID=
GA_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=./ga-credentials.json

# ── Email / SMTP (optional) ─────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@thebooktimes.com

# ── OpenAI (for AI blog generation) ─────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── AI Auto Blog Posting ────────────────────────────────────────────────────
AI_BLOG_ENABLED=false
AI_BLOG_CRON_SCHEDULE=0 9 * * 1
AI_BLOG_POSTS_PER_RUN=1
OPENAI_MAX_DAILY_TOKENS=100000

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Data Retention (days) ────────────────────────────────────────────────────
RETENTION_ANALYTICS_DAYS=90
RETENTION_PAGEVIEWS_DAYS=90
RETENTION_WEBVITALS_DAYS=30
RETENTION_AI_LOG_DAYS=180

# ── Backups ──────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=
